{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "https://doqteforumjdugifxryl.supabase.co/functions/v1/sitemap" },
    { "source": "/sitemap_index.xml", "destination": "https://doqteforumjdugifxryl.supabase.co/functions/v1/sitemap?type=index" },
    { "source": "/sitemap-matches.xml", "destination": "https://doqteforumjdugifxryl.supabase.co/functions/v1/sitemap?type=matches" },
    { "source": "/sitemap-tournaments.xml", "destination": "https://doqteforumjdugifxryl.supabase.co/functions/v1/sitemap?type=tournaments" },
    { "source": "/sitemap-pages.xml", "destination": "https://doqteforumjdugifxryl.supabase.co/functions/v1/sitemap?type=pages" },
    { "source": "/((?!api|_next|.*\\.).*)", "destination": "/" }
  ]
}

